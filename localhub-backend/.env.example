# 이 파일을 복사해서 .env 로 만들어 사용하세요 (cp .env.example .env)
# 실제 .env 는 .gitignore 에 등록되어 있으므로 커밋되지 않습니다.

# SQLite DB 파일 경로
DATABASE_URL=sqlite:///./localhub.db

# CORS 허용 오리진 (프론트 개발 서버 / Netlify 배포 URL)
# 콤마로 여러 개 지정 가능
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 챗봇 담당자용 (현준님) — 지금은 비워둬도 됨
OPENAI_API_KEY=
