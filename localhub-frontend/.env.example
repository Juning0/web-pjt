# FastAPI 챗봇 서버 주소입니다. 끝에 /는 쓰지 않아도 됩니다.
VITE_CHAT_API_BASE_URL=http://127.0.0.1:8000

# LocalHub REST API(장소/게시글) 서버 주소입니다. 끝에 /는 쓰지 않아도 됩니다.
VITE_API_BASE_URL=https://localhub-backend-kvly.onrender.com

# 카카오맵 JavaScript 키 (Kakao Developers > 내 애플리케이션 > 앱 키)
# https://developers.kakao.com 에서 발급, 플랫폼(Web)에 접속 도메인을 등록해야 합니다.
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key
